{
  "name": "pulse-analytics",
  "version": "1.0.0",
  "description": "Social media analytics backend for Instagram & Telegram",
  "main": "server/index.js",
  "scripts": {
    "migrate": "node server/migrate.js",
    "start": "node server/migrate.js && node server/index.js",
    "worker": "node server/migrate.js && node server/worker.js",
    "dev": "node server/migrate.js && node --watch server/index.js",
    "test": "node --test test/*.test.js",
    "lint": "biome lint --diagnostic-level=error",
    "check:syntax": "node scripts/check-server-syntax.mjs",
    "check:migrations": "node scripts/check-migrations.mjs",
    "check:boundaries": "node scripts/check-server-boundaries.mjs",
    "check": "npm run check:syntax && npm run check:migrations && npm run check:boundaries && npm run lint && node --test test/*.test.js"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "node-fetch": "^2.7.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3"
  }
}
