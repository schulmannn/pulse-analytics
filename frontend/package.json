{
  "name": "pulse-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts e2e/campaigns.spec.ts e2e/mentions.spec.ts --project=desktop-1440",
    "typecheck": "tsc --noEmit",
    "build:shared": "esbuild src/lib/narrative.ts --bundle --format=cjs --platform=node --outfile=../server/lib/narrative.gen.cjs",
    "lint:motion": "node scripts/design-motion-lint.mjs",
    "size-check": "node scripts/check-bundle-size.mjs",
    "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.8",
    "@astryxdesign/theme-neutral": "^0.1.8",
    "@fontsource-variable/geist": "^5.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.21",
    "@radix-ui/react-checkbox": "^1.3.9",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.22",
    "@radix-ui/react-label": "^2.1.13",
    "@radix-ui/react-popover": "^1.1.21",
    "@radix-ui/react-progress": "^1.1.14",
    "@radix-ui/react-select": "^2.3.5",
    "@radix-ui/react-separator": "^1.1.13",
    "@radix-ui/react-slot": "^1.3.1",
    "@radix-ui/react-switch": "^1.3.5",
    "@radix-ui/react-tabs": "^1.1.19",
    "@radix-ui/react-tooltip": "^1.2.14",
    "@tanstack/react-query": "^5.101.3",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^1.26.0",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.6.5",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router-dom": "^7.18.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.8",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.22",
    "tailwindcss": "^4.3.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.4",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
