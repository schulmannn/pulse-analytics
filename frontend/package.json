{
  "name": "pulse-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts e2e/campaigns.spec.ts e2e/mentions.spec.ts --project=desktop-1440",
    "typecheck": "tsc --noEmit",
    "build:shared": "esbuild src/lib/narrative.ts --bundle --format=cjs --platform=node --outfile=../server/lib/narrative.gen.cjs",
    "lint:motion": "node scripts/design-motion-lint.mjs",
    "size-check": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.0",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
