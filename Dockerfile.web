# Atlavue — WEB-сервис (Node/Express + дашборд).
# Публичный сервис на Railway ($PORT). К MTProto-микросервису ходит по ПРИВАТНОЙ
# сети Railway через MTPROTO_URL (напр. http://mtproto.railway.internal:8001).
# Часть сплита рантаймов: Python в этом образе НЕТ (см. Dockerfile.mtproto).

# ── Stage 1: build the new frontend (Sprint 3F — Vite/React/TS SPA → static dist) ──
# Post-catover (3F-3): this dist/ is the primary dashboard, served by Express at '/'; the
# legacy public/index.html shell survives only at /legacy as a reversible escape hatch. If
# this stage fails, the whole image fails — so `npm run build` is verified locally before
# this Dockerfile change ships.
FROM node:20-slim AS frontend
WORKDIR /fe
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ ./
# build:shared собирает narrative-движок в CJS для серверного недельного дайджеста
# (server/lib/narrative.gen.cjs = /server/lib в этой стадии — outfile ../server от /fe).
RUN npm run build && npm run build:shared

# ── Stage 2: server runtime ──
FROM node:20-slim

ENV NODE_ENV=production
WORKDIR /app

# Reproducible production dependencies.
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Только то, что нужно вебу (mtproto/ — отдельный сервис, сюда не копируем)
COPY server ./server
# Shared narrative-движок (недельный дайджест в report-email) — собран стадией frontend.
COPY --from=frontend /server/lib/narrative.gen.cjs ./server/lib/narrative.gen.cjs
COPY public ./public
# New frontend build output (served at /).
COPY --from=frontend /fe/dist ./frontend/dist

# The runtime only reads application assets and talks to Postgres/upstreams; keep package install
# and image assembly privileged, then drop to the non-root user provided by node:20-slim.
USER node

CMD ["npm", "start"]
